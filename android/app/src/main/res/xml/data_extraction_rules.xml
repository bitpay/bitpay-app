<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>

    <!--
      Explicitly opt out of BOTH cloud backup and device-to-device transfers.
      This provides an extra layer of protection on Android 12+ devices where
      some OEM migration tools may still transfer app data even when
      android:allowBackup="false" is set.
    -->

    <cloud-backup>
        <!-- Exclude everything from cloud backup. -->
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />

        <!-- Exclude everything in device-protected storage. -->
        <exclude domain="device_root" path="." />
        <exclude domain="device_file" path="." />
        <exclude domain="device_database" path="." />
        <exclude domain="device_sharedpref" path="." />
    </cloud-backup>

    <device-transfer>
        <!-- Exclude everything from device-to-device transfers. -->
        <exclude domain="root" path="." />
        <exclude domain="file" path="." />
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="external" path="." />

        <!-- Exclude everything in device-protected storage. -->
        <exclude domain="device_root" path="." />
        <exclude domain="device_file" path="." />
        <exclude domain="device_database" path="." />
        <exclude domain="device_sharedpref" path="." />
    </device-transfer>

</data-extraction-rules>